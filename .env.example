# Copy to .env and restart Expo (npm start).
# Keys prefixed with EXPO_PUBLIC_ are bundled into the app — use only for local dev,
# or point to your own backend proxy in production.

EXPO_PUBLIC_GEMINI_API_KEY=

# Optional model override (default: gemini-2.0-flash)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-3.5-flash
# EXPO_PUBLIC_GEMINI_MAX_OUTPUT_TOKENS=1024

# Optional: POST JSON { "context": { ... } } → { "tips": ["...", ...] }
# When set, this URL is used instead of calling Gemini directly from the device.
EXPO_PUBLIC_HEALTH_INSIGHTS_API_URL=
