# Copy to .env and restart Expo (npm start).
# Keys prefixed with EXPO_PUBLIC_ are bundled into the app — use only for local dev,
# or point to your own backend proxy in production.

EXPO_PUBLIC_OPENAI_API_KEY=

# Optional model override (default: gpt-4o-mini)
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
# EXPO_PUBLIC_OPENAI_MAX_OUTPUT_TOKENS=1024
# EXPO_PUBLIC_OPENAI_TEMPERATURE=0.6

# Optional: POST JSON { "context": { ... }, "kind": "routine" | "insights" }
# Insights: returns { "insights", "recommendations", "questions" }
# Routine: returns { "options": [{ "id", "primaryGoalId", "whyThisGoal", "intro", "steps" }] } — exactly 3
# When set, this URL is used instead of calling OpenAI directly from the device.
EXPO_PUBLIC_HEALTH_INSIGHTS_API_URL=

# Firebase Client Configuration (Required for Google Sign-In & cloud backup)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Authentication Client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
